{
  "name": "fs25-planner-api",
  "version": "0.1.0",
  "private": true,
  "description": "FS25 Farm Planner API — REST backend (Fastify 5 + TypeScript)",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun run src/server.ts",
    "worker": "bun run src/worker.ts",
    "worker:dev": "bun --watch src/worker.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@node-rs/argon2": "^2.0.0",
    "bullmq": "^5.28.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "pm2": "^5.4.3",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.14.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vitest": "^2.1.5"
  }
}
