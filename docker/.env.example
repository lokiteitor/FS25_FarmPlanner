# =============================================================================
# FS25 Farm Planner - variables de entorno de Docker Compose
# -----------------------------------------------------------------------------
# Copiar a "docker/.env" y ajustar antes de desplegar:
#   cp docker/.env.example docker/.env
#
# docker compose lee este fichero automaticamente (mismo directorio que el
# docker-compose.yml). NO commitear el .env real (esta en .gitignore).
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=fs25_planner
POSTGRES_USER=fs25_planner
# IMPORTANTE: cambiar en produccion por un valor fuerte.
POSTGRES_PASSWORD=fs25_planner

# --- Autenticacion / JWT -----------------------------------------------------
# IMPORTANTE: cambiar en produccion por un secreto aleatorio (>= 32 caracteres).
JWT_SECRET=change-me-in-prod-please-32chars-min
# Vida del access token en segundos (~15 min).
ACCESS_TOKEN_TTL=900
# Vida del refresh token en dias (~30 dias).
REFRESH_TOKEN_TTL_DAYS=30

# --- Rate limiting -----------------------------------------------------------
# Maximo de peticiones por ventana en endpoints sensibles (login/register).
RATE_LIMIT_MAX=10

# --- Worker / BullMQ ---------------------------------------------------------
# Activa el job opcional de limpieza de refresh_tokens expirados (ADR-007).
ENABLE_TOKEN_CLEANUP=false

# --- Observabilidad ----------------------------------------------------------
# Nivel de log de pino: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- nginx -------------------------------------------------------------------
# Puerto del host publicado por nginx (host -> contenedor 80).
NGINX_HTTP_PORT=80
